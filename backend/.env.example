# Copy this to .env and fill in your values

# ── Google Sheets ──────────────────────────────────────────────
# Paste the full contents of your service account credentials.json here (as one line)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"..."}

# (Optional) Google Drive folder ID to save sheets into a specific folder
GOOGLE_DRIVE_FOLDER_ID=

# ── Email (Gmail SMTP) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
# Create an App Password at https://myaccount.google.com/apppasswords
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
